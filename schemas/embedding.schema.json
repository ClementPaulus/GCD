{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/embedding.schema.json",
  "title": "UMCP Embedding Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "embedding"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "schemas/embedding.schema.json"
    },
    "embedding": {
      "type": "object",
      "required": ["id", "version", "source_space", "target_space", "transform"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source_space": {
          "type": "object",
          "required": ["channels"],
          "additionalProperties": true,
          "properties": {
            "description": { "type": "string" },
            "channels": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name"],
                "additionalProperties": true,
                "properties": {
                  "name": { "type": "string" },
                  "unit": { "type": "string" },
                  "physical_range": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              }
            }
          }
        },
        "target_space": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "description": { "type": "string" },
            "interval": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "coordinates": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "transform": {
          "type": "object",
          "required": ["method"],
          "additionalProperties": true,
          "properties": {
            "method": { "type": "string" },
            "formula": { "type": "string" },
            "parameters": {
              "type": "object",
              "additionalProperties": true
            },
            "face": { "type": "string" },
            "epsilon": { "type": "number" }
          }
        },
        "oor_policy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "method": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
