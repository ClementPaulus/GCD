---
import BaseLayout from '../layouts/BaseLayout.astro';
import PrecisionVerifier from '../components/PrecisionVerifier.astro';
---

<BaseLayout title="Precision Verification — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Precision Verification</h1>
      <p class="text-kernel-400">
        Verify kernel identities, inspect regime gates, diagnose conformance gaps,
        and explore cross-domain presets. All computation runs client-side.
      </p>
    </div>
    <PrecisionVerifier />
  </div>
</BaseLayout>
