    <section id="math-foundations" class="mb-10">
      <div class="bg-kernel-900/50 border border-kernel-700/40 rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-kernel-700/40 border border-kernel-700/30 flex items-center justify-center text-kernel-300 font-mono text-lg">∫</div>
