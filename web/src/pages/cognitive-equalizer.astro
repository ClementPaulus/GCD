  <!-- ═══════ CLIENT-SIDE SCRIPT ═══════ -->
  <script>
    import {
      engage, ceKernel, formatReport, channelsToVector, defaultChannels,
      CE_CHANNEL_NAMES, CE_CHANNEL_LABELS, CE_CHANNEL_QUESTIONS,
      CE_PRESETS, CE_SYSTEM_PROMPT,
      type CEChannels, type CEReport,
    } from '../lib/cognitive-equalizer';

    /* ── State ─────────────────────────────── */
    let currentChannels: CEChannels = {
      relevance: 0.85, accuracy: 0.80, completeness: 0.75, consistency: 0.90,
      traceability: 0.70, groundedness: 0.82, constraintRespect: 0.88, returnFidelity: 0.78,
    };

    /* ── Tab switching ─────────────────────── */
    const tabs = document.querySelectorAll('.ce-tab') as NodeListOf<HTMLButtonElement>;
    const panels = document.querySelectorAll('.ce-panel') as NodeListOf<HTMLElement>;

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => {
          t.classList.remove('active', 'bg-amber-500/20', 'text-amber-400', 'border-amber-500/30');
          t.classList.add('text-kernel-500', 'border-transparent');
        });
        tab.classList.add('active', 'bg-amber-500/20', 'text-amber-400', 'border-amber-500/30');
        tab.classList.remove('text-kernel-500', 'border-transparent');

        panels.forEach(p => p.classList.add('hidden'));
        document.getElementById(`tab-${target}`)?.classList.remove('hidden');
      });
    });

    /* ── Build channel sliders ─────────────── */
    const slidersContainer = document.getElementById('channel-sliders')!;
    const CHANNEL_COLORS = [
      'text-green-400', 'text-cyan-400', 'text-blue-400', 'text-purple-400',
      'text-pink-400', 'text-amber-400', 'text-orange-400', 'text-red-400',
    ];

    CE_CHANNEL_NAMES.forEach((name, i) => {
      const label = CE_CHANNEL_LABELS[name];
      const value = (currentChannels as any)[name] as number;
      const color = CHANNEL_COLORS[i];

      const row = document.createElement('div');
      row.className = 'space-y-1';
      row.innerHTML = `
        <div class="flex items-center justify-between">
          <label class="text-xs font-medium ${color}" title="${CE_CHANNEL_QUESTIONS[name]}">${label}</label>
          <span class="text-xs font-mono text-kernel-400" id="val-${name}">${value.toFixed(2)}</span>
        </div>
        <input type="range" min="0" max="100" value="${Math.round(value * 100)}"
          class="w-full h-1.5 rounded-full appearance-none cursor-pointer bg-kernel-800
          [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-3.5 [&::-webkit-slider-thumb]:h-3.5
          [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-amber-400
          [&::-webkit-slider-thumb]:shadow-lg [&::-webkit-slider-thumb]:cursor-pointer"
          id="slider-${name}" data-channel="${name}" />
        <div class="text-[9px] text-kernel-600">${CE_CHANNEL_QUESTIONS[name]}</div>
      `;
      slidersContainer.appendChild(row);

      const slider = row.querySelector(`#slider-${name}`) as HTMLInputElement;
      slider.addEventListener('input', () => {
        const v = parseInt(slider.value) / 100;
        (currentChannels as any)[name] = v;
        document.getElementById(`val-${name}`)!.textContent = v.toFixed(2);
      });
    });

    /* ── Evaluate ─────────────────────────── */
    function runEvaluation() {
      const report = engage(currentChannels);
      updateDisplay(report);
      updateLedgerDive(report);
      addToHistory(report);
    }

    function updateDisplay(report: CEReport) {
      // Verdict badge
      const badge = document.getElementById('verdict-badge')!;
      badge.textContent = report.stance;
      badge.className = 'inline-block px-6 py-3 rounded-xl text-2xl font-black tracking-wider border-2 ';
      if (report.stance === 'CONFORMANT') {
        badge.className += 'border-green-500/50 text-green-400 bg-green-500/10';
      } else if (report.stance === 'NONCONFORMANT') {
        badge.className += 'border-red-500/50 text-red-400 bg-red-500/10';
      } else {
        badge.className += 'border-amber-500/50 text-amber-400 bg-amber-500/10';
      }

      // Regime badge
      const regimeBadge = document.getElementById('regime-badge')!;
      const regimeColor = report.regime === 'STABLE' ? 'text-green-400' : report.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
      const criticalText = report.isCritical ? '<span class="text-red-500 font-bold">YES</span>' : '<span class="text-kernel-500">No</span>';
      regimeBadge.innerHTML = `Regime: <span class="${regimeColor} font-bold">${report.regime}</span> · Critical: ${criticalText}`;

      // Invariants
      const kr = report.kernel;
      document.getElementById('inv-F')!.textContent = kr.F.toFixed(4);
      document.getElementById('inv-omega')!.textContent = kr.omega.toFixed(4);
      document.getElementById('inv-S')!.textContent = kr.S.toFixed(4);
      document.getElementById('inv-C')!.textContent = kr.C.toFixed(4);
      document.getElementById('inv-kappa')!.textContent = kr.kappa.toFixed(4);
      document.getElementById('inv-IC')!.textContent = kr.IC.toFixed(4);
      document.getElementById('inv-delta')!.textContent = kr.delta.toFixed(4);
      document.getElementById('invariants-panel')!.classList.remove('hidden');

      // Full report
      document.getElementById('report-text')!.textContent = formatReport(report);
      document.getElementById('spine-report')!.classList.remove('hidden');

      // Radar chart
      drawRadar(report);
    }

    document.getElementById('btn-evaluate')!.addEventListener('click', runEvaluation);
    document.getElementById('btn-reset')!.addEventListener('click', () => {
      currentChannels = {
        relevance: 0.85, accuracy: 0.80, completeness: 0.75, consistency: 0.90,
        traceability: 0.70, groundedness: 0.82, constraintRespect: 0.88, returnFidelity: 0.78,
      };
      CE_CHANNEL_NAMES.forEach(name => {
        const v = (currentChannels as any)[name] as number;
        (document.getElementById(`slider-${name}`) as HTMLInputElement).value = String(Math.round(v * 100));
        document.getElementById(`val-${name}`)!.textContent = v.toFixed(2);
      });
    });

    /* ── Radar chart ─────────────────────── */
    function drawRadar(report: CEReport) {
      const canvas = document.getElementById('radar-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width;
      const h = canvas.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(cx, cy) - 40;

      ctx.clearRect(0, 0, w, h);

      const vec = channelsToVector(report.channels);
      const n = vec.length;
      const labels = CE_CHANNEL_NAMES.map(n => CE_CHANNEL_LABELS[n]);

      // Draw grid circles
      for (let ring = 0.25; ring <= 1.0; ring += 0.25) {
        ctx.beginPath();
        for (let i = 0; i <= n; i++) {
          const angle = (i % n) * (2 * Math.PI / n) - Math.PI / 2;
          const x = cx + r * ring * Math.cos(angle);
          const y = cy + r * ring * Math.sin(angle);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = 'rgba(148, 163, 184, 0.12)';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Ring label
        ctx.fillStyle = 'rgba(148, 163, 184, 0.3)';
        ctx.font = '9px monospace';
        ctx.fillText(ring.toFixed(2), cx + 3, cy - r * ring + 3);
      }

      // Draw axis lines
      for (let i = 0; i < n; i++) {
        const angle = i * (2 * Math.PI / n) - Math.PI / 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
        ctx.strokeStyle = 'rgba(148, 163, 184, 0.08)';
        ctx.stroke();

        // Label
        const lx = cx + (r + 25) * Math.cos(angle);
        const ly = cy + (r + 25) * Math.sin(angle);
        ctx.fillStyle = CHANNEL_COLORS[i].includes('green') ? '#4ade80' :
                        CHANNEL_COLORS[i].includes('cyan') ? '#22d3ee' :
                        CHANNEL_COLORS[i].includes('blue') ? '#60a5fa' :
                        CHANNEL_COLORS[i].includes('purple') ? '#a78bfa' :
                        CHANNEL_COLORS[i].includes('pink') ? '#f472b6' :
                        CHANNEL_COLORS[i].includes('amber') ? '#fbbf24' :
                        CHANNEL_COLORS[i].includes('orange') ? '#fb923c' : '#f87171';
        ctx.font = '9px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        // Shorter labels for display
        const shortLabels = ['Rel', 'Acc', 'Cmp', 'Con', 'Trc', 'Gnd', 'Cst', 'Ret'];
        ctx.fillText(shortLabels[i], lx, ly);
      }

      // Draw data polygon
      ctx.beginPath();
      for (let i = 0; i <= n; i++) {
        const angle = (i % n) * (2 * Math.PI / n) - Math.PI / 2;
        const val = vec[i % n];
        const x = cx + r * val * Math.cos(angle);
        const y = cy + r * val * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      const fillColor = report.stance === 'CONFORMANT' ? 'rgba(74, 222, 128, 0.15)' :
                        report.stance === 'NONCONFORMANT' ? 'rgba(248, 113, 113, 0.15)' :
                        'rgba(251, 191, 36, 0.15)';
      const strokeColor = report.stance === 'CONFORMANT' ? '#4ade80' :
                          report.stance === 'NONCONFORMANT' ? '#f87171' : '#fbbf24';
      ctx.fillStyle = fillColor;
      ctx.fill();
      ctx.strokeStyle = strokeColor;
      ctx.lineWidth = 2;
      ctx.stroke();

      // Draw data points
      for (let i = 0; i < n; i++) {
        const angle = i * (2 * Math.PI / n) - Math.PI / 2;
        const val = vec[i];
        const x = cx + r * val * Math.cos(angle);
        const y = cy + r * val * Math.sin(angle);
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, 2 * Math.PI);
        ctx.fillStyle = val < 0.3 ? '#f87171' : strokeColor;
        ctx.fill();
      }

      // Draw F and IC lines
      const fRadius = r * report.kernel.F;
      ctx.beginPath();
      ctx.arc(cx, cy, fRadius, 0, 2 * Math.PI);
      ctx.strokeStyle = 'rgba(74, 222, 128, 0.3)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.stroke();

      const icRadius = r * report.kernel.IC;
      ctx.beginPath();
      ctx.arc(cx, cy, icRadius, 0, 2 * Math.PI);
      ctx.strokeStyle = 'rgba(248, 113, 113, 0.3)';
      ctx.stroke();
      ctx.setLineDash([]);

      // Legend
      ctx.font = '9px monospace';
      ctx.textAlign = 'left';
      ctx.fillStyle = 'rgba(74, 222, 128, 0.6)';
      ctx.fillText(`F = ${report.kernel.F.toFixed(3)}`, 8, h - 24);
      ctx.fillStyle = 'rgba(248, 113, 113, 0.6)';
      ctx.fillText(`IC = ${report.kernel.IC.toFixed(3)}`, 8, h - 12);
      ctx.fillStyle = 'rgba(251, 191, 36, 0.6)';
      ctx.fillText(`Δ = ${report.kernel.delta.toFixed(3)}`, 90, h - 12);
    }

    /* ── Preset grid ─────────────────────── */
    const presetGrid = document.getElementById('preset-grid')!;
    CE_PRESETS.forEach((preset, idx) => {
      const report = engage(preset.channels);
      const kr = report.kernel;

      const card = document.createElement('div');
      card.className = 'bg-kernel-900/50 border border-kernel-700/50 rounded-xl p-5 cursor-pointer hover:border-amber-500/30 transition-all';
      const stanceColor = report.stance === 'CONFORMANT' ? 'text-green-400' : report.stance === 'NONCONFORMANT' ? 'text-red-400' : 'text-amber-400';
      const regimeColor = report.regime === 'STABLE' ? 'text-green-400' : report.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
      const critBadge = report.isCritical ? '<span class="text-red-500 text-[9px] font-bold ml-1">CRITICAL</span>' : '';

      card.innerHTML = `
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-sm font-bold text-kernel-200">${preset.name}</h4>
          <span class="${stanceColor} text-xs font-bold font-mono">${report.stance}</span>
        </div>
        <p class="text-kernel-500 text-xs mb-3">${preset.description}</p>
        <div class="grid grid-cols-4 gap-2 text-[10px] font-mono">
          <div><span class="text-kernel-600">F</span> <span class="text-green-400">${kr.F.toFixed(3)}</span></div>
          <div><span class="text-kernel-600">IC</span> <span class="text-red-400">${kr.IC.toFixed(3)}</span></div>
          <div><span class="text-kernel-600">Δ</span> <span class="text-amber-400">${kr.delta.toFixed(3)}</span></div>
          <div><span class="text-kernel-600">ω</span> <span class="text-kernel-400">${kr.omega.toFixed(3)}</span></div>
        </div>
        <div class="mt-2 text-[10px]">
          <span class="${regimeColor} font-bold">${report.regime}</span>${critBadge}
        </div>
      `;

      card.addEventListener('click', () => {
        // Load preset into sliders
        currentChannels = { ...preset.channels };
        CE_CHANNEL_NAMES.forEach(name => {
          const v = (currentChannels as any)[name] as number;
          (document.getElementById(`slider-${name}`) as HTMLInputElement).value = String(Math.round(v * 100));
          document.getElementById(`val-${name}`)!.textContent = v.toFixed(2);
        });
        // Switch to interactive tab and evaluate
        (document.querySelector('[data-tab="interactive"]') as HTMLButtonElement).click();
        runEvaluation();
      });

      presetGrid.appendChild(card);
    });

    /* ── Channel Reference ────────────────── */
    const channelRef = document.getElementById('channel-reference')!;
    CE_CHANNEL_NAMES.forEach((name, i) => {
      const div = document.createElement('div');
      div.className = 'flex items-start gap-3 bg-kernel-800/40 rounded-lg p-3 border border-kernel-700/20';
      const color = CHANNEL_COLORS[i];
      div.innerHTML = `
        <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-kernel-700/40 flex items-center justify-center text-sm font-bold ${color}">${i + 1}</div>
        <div>
          <div class="text-sm font-bold ${color}">${CE_CHANNEL_LABELS[name]}</div>
          <div class="text-xs text-kernel-400 mt-0.5">${CE_CHANNEL_QUESTIONS[name]}</div>
          <div class="text-[10px] text-kernel-600 mt-1 font-mono">${name} ∈ [0.0, 1.0] · weight = 1/8</div>
        </div>
      `;
      channelRef.appendChild(div);
    });

    /* ── System Prompt tab ─────────────────── */
    document.getElementById('prompt-text')!.textContent = CE_SYSTEM_PROMPT;

    function copyPrompt() {
      navigator.clipboard.writeText(CE_SYSTEM_PROMPT).then(() => {
        const btn = document.getElementById('btn-copy-prompt')!;
        btn.textContent = 'Copied!';
        btn.classList.add('bg-green-600');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('bg-green-600'); }, 2000);
      });
    }
    document.getElementById('btn-copy-prompt')?.addEventListener('click', copyPrompt);
    document.getElementById('btn-copy-prompt-dl')?.addEventListener('click', copyPrompt);

    /* ── Download links ─────────────────────── */
    function makeDownloadLink(id: string, filename: string, content: string, mimeType = 'text/plain') {
      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const el = document.getElementById(id) as HTMLAnchorElement;
      if (el) {
        el.href = url;
        el.download = filename;
      }
    }

    // Prompt download
    makeDownloadLink('dl-prompt', 'ce-system-prompt.txt', CE_SYSTEM_PROMPT);

    // For Python and TypeScript, we fetch the actual source files
    const base = import.meta.env.BASE_URL || '/';

    // Python source — fetch from GitHub raw
    fetch('https://raw.githubusercontent.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS/main/src/umcp/cognitive_equalizer.py')
      .then(r => r.ok ? r.text() : Promise.reject('Failed'))
      .then(text => makeDownloadLink('dl-python', 'cognitive_equalizer.py', text, 'text/x-python'))
      .catch(() => {
        // Fallback: generate a stub that points to the repo
        makeDownloadLink('dl-python', 'cognitive_equalizer.py',
          '# Full source: https://github.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS/blob/main/src/umcp/cognitive_equalizer.py\n# Install: pip install umcp\n# Then: from umcp.cognitive_equalizer import CognitiveEqualizer\n',
          'text/x-python');
      });

    // TypeScript source — fetch from GitHub raw
    fetch('https://raw.githubusercontent.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS/main/web/src/lib/cognitive-equalizer.ts')
      .then(r => r.ok ? r.text() : Promise.reject('Failed'))
      .then(text => makeDownloadLink('dl-typescript', 'cognitive-equalizer.ts', text, 'text/typescript'))
      .catch(() => {
        makeDownloadLink('dl-typescript', 'cognitive-equalizer.ts',
          '// Full source: https://github.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS/blob/main/web/src/lib/cognitive-equalizer.ts\n',
          'text/typescript');
      });

    /* ═══════════════════════════════════════════════════════════
       §1  GEOMETRIC SLAUGHTER LAB
       ═══════════════════════════════════════════════════════════ */
    const killSlider = document.getElementById('kill-slider') as HTMLInputElement;
    const killChannelSelect = document.getElementById('kill-channel-select') as HTMLSelectElement;
    const killValueLabel = document.getElementById('kill-value-label')!;
    const killFBar = document.getElementById('kill-F-bar') as HTMLDivElement;
    const killICBar = document.getElementById('kill-IC-bar') as HTMLDivElement;
    const killDeltaBar = document.getElementById('kill-delta-bar') as HTMLDivElement;
    const killFVal = document.getElementById('kill-F-val')!;
    const killICVal = document.getElementById('kill-IC-val')!;
    const killDeltaVal = document.getElementById('kill-delta-val')!;

    function updateSlaughterLab() {
      const killVal = parseInt(killSlider.value) / 100;
      const killIdx = parseInt(killChannelSelect.value);
      killValueLabel.textContent = killVal.toFixed(2);

      // Build channel vector: all 0.90 except killed channel
      const baseVal = 0.90;
      const channels: Record<string, number> = {};
      CE_CHANNEL_NAMES.forEach((name, i) => {
        channels[name] = i === killIdx ? killVal : baseVal;
      });
      const report = engage(channels as any);
      const kr = report.kernel;

      // Update bars
      killFBar.style.width = `${kr.F * 100}%`;
      killICBar.style.width = `${kr.IC * 100}%`;
      killDeltaBar.style.width = `${kr.delta * 100}%`;
      killFVal.textContent = kr.F.toFixed(4);
      killICVal.textContent = kr.IC.toFixed(4);
      killDeltaVal.textContent = kr.delta.toFixed(4);

      // Draw sweep canvas
      drawSlaughterSweep(killIdx, killVal);
    }

    function drawSlaughterSweep(killIdx: number, currentKill: number) {
      const canvas = document.getElementById('slaughter-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width, h = canvas.height;
      const pad = { top: 20, right: 20, bottom: 30, left: 45 };
      const pw = w - pad.left - pad.right;
      const ph = h - pad.top - pad.bottom;

      ctx.clearRect(0, 0, w, h);

      // Grid
      ctx.strokeStyle = 'rgba(150, 150, 150, 0.1)';
      ctx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = pad.top + (ph * i / 4);
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
      }

      // Sweep data
      const baseVal = 0.90;
      const steps = 100;
      const fData: number[] = [];
      const icData: number[] = [];
      const deltaData: number[] = [];
      for (let s = 0; s <= steps; s++) {
        const v = s / steps;
        const ch: Record<string, number> = {};
        CE_CHANNEL_NAMES.forEach((name, i) => { ch[name] = i === killIdx ? v : baseVal; });
        const r = engage(ch as any);
        fData.push(r.kernel.F);
        icData.push(r.kernel.IC);
        deltaData.push(r.kernel.delta);
      }

      // Draw curves
      function drawCurve(data: number[], color: string) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        data.forEach((val, i) => {
          const x = pad.left + (i / steps) * pw;
          const y = pad.top + ph * (1 - val);
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();
      }
      drawCurve(fData, '#4ade80');
      drawCurve(icData, '#f87171');
      drawCurve(deltaData, '#fbbf24');

      // Current position marker
      const curStep = Math.round(currentKill * steps);
      const cx = pad.left + (curStep / steps) * pw;
      // Draw vertical line at current position
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(34, 211, 238, 0.3)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.moveTo(cx, pad.top); ctx.lineTo(cx, pad.top + ph);
      ctx.stroke();
      ctx.setLineDash([]);

      // Dots at current position
      [fData, icData, deltaData].forEach((data, di) => {
        const colors = ['#4ade80', '#f87171', '#fbbf24'];
        const y = pad.top + ph * (1 - data[curStep]);
        ctx.beginPath();
        ctx.arc(cx, y, 4, 0, Math.PI * 2);
        ctx.fillStyle = colors[di];
        ctx.fill();
        ctx.strokeStyle = '#0a0a0a';
        ctx.lineWidth = 1.5;
        ctx.stroke();
      });

      // Axes labels
      ctx.fillStyle = '#71717a';
      ctx.font = '9px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('0.0', pad.left, pad.top + ph + 15);
      ctx.fillText('0.5', pad.left + pw / 2, pad.top + ph + 15);
      ctx.fillText('1.0', pad.left + pw, pad.top + ph + 15);
      ctx.fillText('channel value →', pad.left + pw / 2, pad.top + ph + 27);
      ctx.textAlign = 'right';
      ctx.fillText('1.0', pad.left - 5, pad.top + 4);
      ctx.fillText('0.5', pad.left - 5, pad.top + ph / 2 + 4);
      ctx.fillText('0.0', pad.left - 5, pad.top + ph + 4);
    }

    killSlider.addEventListener('input', updateSlaughterLab);
    killChannelSelect.addEventListener('change', updateSlaughterLab);
    updateSlaughterLab();

    /* ═══════════════════════════════════════════════════════════
       §2  COMPARISON MODE
       ═══════════════════════════════════════════════════════════ */
    const compareA = document.getElementById('compare-a') as HTMLSelectElement;
    const compareB = document.getElementById('compare-b') as HTMLSelectElement;
    CE_PRESETS.forEach((p, i) => {
      const optA = document.createElement('option');
      optA.value = String(i);
      optA.textContent = p.name;
      compareA.appendChild(optA);
      const optB = document.createElement('option');
      optB.value = String(i);
      optB.textContent = p.name;
      compareB.appendChild(optB);
    });
    if (compareB.options.length > 1) compareB.selectedIndex = 1;

    function runComparison() {
      const idxA = parseInt(compareA.value);
      const idxB = parseInt(compareB.value);
      const rA = engage(CE_PRESETS[idxA].channels);
      const rB = engage(CE_PRESETS[idxB].channels);

      function makeCard(name: string, report: ReturnType<typeof engage>): string {
        const kr = report.kernel;
        const sc = report.stance === 'CONFORMANT' ? 'text-green-400' : report.stance === 'NONCONFORMANT' ? 'text-red-400' : 'text-amber-400';
        const rc = report.regime === 'STABLE' ? 'text-green-400' : report.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
        const crit = report.isCritical ? ' <span class="text-red-500 text-[9px]">CRITICAL</span>' : '';
        return `
          <h4 class="text-sm font-bold text-kernel-200 mb-1">${name}</h4>
          <div class="flex gap-3 text-xs mb-2"><span class="${sc} font-bold font-mono">${report.stance}</span><span class="${rc} font-mono">${report.regime}${crit}</span></div>
          <div class="grid grid-cols-3 gap-2 text-[10px] font-mono">
            <div><span class="text-kernel-600">F</span> <span class="text-green-400">${kr.F.toFixed(3)}</span></div>
            <div><span class="text-kernel-600">IC</span> <span class="text-red-400">${kr.IC.toFixed(3)}</span></div>
            <div><span class="text-kernel-600">Δ</span> <span class="text-amber-400">${kr.delta.toFixed(3)}</span></div>
            <div><span class="text-kernel-600">ω</span> <span class="text-kernel-400">${kr.omega.toFixed(3)}</span></div>
            <div><span class="text-kernel-600">S</span> <span class="text-cyan-400">${kr.S.toFixed(3)}</span></div>
            <div><span class="text-kernel-600">C</span> <span class="text-purple-400">${kr.C.toFixed(3)}</span></div>
          </div>
        `;
      }

      document.getElementById('compare-card-a')!.innerHTML = makeCard(CE_PRESETS[idxA].name, rA);
      document.getElementById('compare-card-b')!.innerHTML = makeCard(CE_PRESETS[idxB].name, rB);

      // Channel bars
      const barsEl = document.getElementById('compare-bars')!;
      barsEl.innerHTML = '';
      const vecA = channelsToVector(CE_PRESETS[idxA].channels);
      const vecB = channelsToVector(CE_PRESETS[idxB].channels);
      CE_CHANNEL_NAMES.forEach((name, i) => {
        const label = CE_CHANNEL_LABELS[name];
        const vA = vecA[i], vB = vecB[i];
        const diff = vA - vB;
        const diffColor = diff > 0.05 ? 'text-green-400' : diff < -0.05 ? 'text-red-400' : 'text-kernel-500';
        const row = document.createElement('div');
        row.className = 'grid grid-cols-[120px_1fr_40px_1fr_40px_40px] gap-2 items-center text-[10px]';
        row.innerHTML = `
          <span class="text-kernel-400 truncate">${label}</span>
          <div class="h-2 bg-kernel-900 rounded-full overflow-hidden"><div class="h-full bg-cyan-500/50 rounded-full" style="width:${vA*100}%"></div></div>
          <span class="font-mono text-kernel-300 text-right">${vA.toFixed(2)}</span>
          <div class="h-2 bg-kernel-900 rounded-full overflow-hidden"><div class="h-full bg-amber-500/50 rounded-full" style="width:${vB*100}%"></div></div>
          <span class="font-mono text-kernel-300 text-right">${vB.toFixed(2)}</span>
          <span class="font-mono ${diffColor} text-right">${diff >= 0 ? '+' : ''}${diff.toFixed(2)}</span>
        `;
        barsEl.appendChild(row);
      });

      document.getElementById('compare-results')!.classList.remove('hidden');
    }

    document.getElementById('btn-compare')?.addEventListener('click', runComparison);

    /* ═══════════════════════════════════════════════════════════
       §3  INTEGRITY LEDGER DEEP DIVE
       ═══════════════════════════════════════════════════════════ */
    function updateLedgerDive(report: ReturnType<typeof engage>) {
      const ledger = report.ledger;
      document.getElementById('ldg-drift')!.textContent = ledger.D_drift.toFixed(6);
      document.getElementById('ldg-rough')!.textContent = ledger.D_roughness.toFixed(4);
      document.getElementById('ldg-balance')!.textContent = ledger.deltaKappa.toFixed(6);

      const balLabel = document.getElementById('ldg-balanced-label')!;
      if (ledger.balanced) {
        balLabel.innerHTML = '<span class="text-green-400">BALANCED</span> — |Δκ| ≤ 0.005';
      } else {
        balLabel.innerHTML = '<span class="text-red-400">UNBALANCED</span> — |Δκ| > 0.005';
      }

      // Draw Γ(ω) curve
      drawGammaCurve(report.kernel.omega);
    }

    function drawGammaCurve(currentOmega: number) {
      const canvas = document.getElementById('gamma-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width, h = canvas.height;
      const pad = { top: 15, right: 20, bottom: 25, left: 50 };
      const pw = w - pad.left - pad.right;
      const ph = h - pad.top - pad.bottom;

      ctx.clearRect(0, 0, w, h);

      // Grid
      ctx.strokeStyle = 'rgba(150, 150, 150, 0.1)';
      ctx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = pad.top + (ph * i / 4);
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
      }

      // Compute Γ(ω) for ω in [0, 0.95] (capped to avoid the pole)
      const eps = 1e-8;
      const maxOmega = 0.95;
      const steps = 200;
      const maxGamma = 2.0; // visual cap
      ctx.beginPath();
      ctx.strokeStyle = '#a855f7';
      ctx.lineWidth = 2;
      for (let s = 0; s <= steps; s++) {
        const om = (s / steps) * maxOmega;
        const gamma = Math.min(Math.pow(om, 3) / (1 - om + eps), maxGamma);
        const x = pad.left + (om / maxOmega) * pw;
        const y = pad.top + ph * (1 - gamma / maxGamma);
        s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();

      // Threshold lines
      // ω = 0.038 (stable boundary)
      const x038 = pad.left + (0.038 / maxOmega) * pw;
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(74, 222, 128, 0.3)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.moveTo(x038, pad.top); ctx.lineTo(x038, pad.top + ph);
      ctx.stroke();
      ctx.setLineDash([]);

      // ω = 0.30 (collapse boundary)
      const x030 = pad.left + (0.30 / maxOmega) * pw;
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(248, 113, 113, 0.3)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.moveTo(x030, pad.top); ctx.lineTo(x030, pad.top + ph);
      ctx.stroke();
      ctx.setLineDash([]);

      // Current ω dot
      if (currentOmega >= 0 && currentOmega <= maxOmega) {
        const cx = pad.left + (currentOmega / maxOmega) * pw;
        const gamma = Math.min(Math.pow(currentOmega, 3) / (1 - currentOmega + eps), maxGamma);
        const cy = pad.top + ph * (1 - gamma / maxGamma);
        ctx.beginPath();
        ctx.arc(cx, cy, 5, 0, Math.PI * 2);
        ctx.fillStyle = '#22d3ee';
        ctx.fill();
        ctx.strokeStyle = '#0a0a0a';
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }

      // Axis labels
      ctx.fillStyle = '#71717a';
      ctx.font = '9px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('0', pad.left, pad.top + ph + 14);
      ctx.fillText(`${maxOmega}`, w - pad.right, pad.top + ph + 14);
      ctx.fillText('ω →', pad.left + pw / 2, pad.top + ph + 22);
      ctx.textAlign = 'right';
      ctx.fillText('0', pad.left - 5, pad.top + ph + 4);
      ctx.fillText(`${maxGamma.toFixed(1)}`, pad.left - 5, pad.top + 4);
      ctx.fillText('Γ(ω)', pad.left - 5, pad.top + ph / 2 + 4);

      // Regime labels
      ctx.font = '8px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillStyle = 'rgba(74, 222, 128, 0.5)';
      ctx.fillText('Stable', (pad.left + x038) / 2, pad.top + 10);
      ctx.fillStyle = 'rgba(251, 191, 36, 0.5)';
      ctx.fillText('Watch', (x038 + x030) / 2, pad.top + 10);
      ctx.fillStyle = 'rgba(248, 113, 113, 0.5)';
      ctx.fillText('Collapse', x030 + 40, pad.top + 10);
    }

    /* ═══════════════════════════════════════════════════════════
       §4  SESSION HISTORY
       ═══════════════════════════════════════════════════════════ */
    interface HistoryEntry {
      num: number;
      F: number;
      IC: number;
      delta: number;
      omega: number;
      regime: string;
      stance: string;
      weakChannel: string;
    }
    const sessionHistory: HistoryEntry[] = [];

    function addToHistory(report: ReturnType<typeof engage>) {
      const kr = report.kernel;
      const vec = channelsToVector(report.channels);
      let weakIdx = 0;
      let weakVal = vec[0];
      for (let i = 1; i < vec.length; i++) {
        if (vec[i] < weakVal) { weakVal = vec[i]; weakIdx = i; }
      }
      const entry: HistoryEntry = {
        num: sessionHistory.length + 1,
        F: kr.F,
        IC: kr.IC,
        delta: kr.delta,
        omega: kr.omega,
        regime: report.regime,
        stance: report.stance,
        weakChannel: CE_CHANNEL_LABELS[CE_CHANNEL_NAMES[weakIdx]] + ` (${weakVal.toFixed(2)})`,
      };
      sessionHistory.push(entry);
      renderHistory();
    }

    function renderHistory() {
      const empty = document.getElementById('history-empty')!;
      const wrapper = document.getElementById('history-table-wrapper')!;
      const trajWrapper = document.getElementById('trajectory-wrapper')!;
      const body = document.getElementById('history-body')!;

      if (sessionHistory.length === 0) {
        empty.classList.remove('hidden');
        wrapper.classList.add('hidden');
        trajWrapper.classList.add('hidden');
        return;
      }
      empty.classList.add('hidden');
      wrapper.classList.remove('hidden');
      trajWrapper.classList.remove('hidden');

      body.innerHTML = '';
      sessionHistory.forEach(e => {
        const rc = e.regime === 'STABLE' ? 'text-green-400' : e.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
        const sc = e.stance === 'CONFORMANT' ? 'text-green-400' : e.stance === 'NONCONFORMANT' ? 'text-red-400' : 'text-amber-400';
        const tr = document.createElement('tr');
        tr.className = 'border-b border-kernel-800/30';
        tr.innerHTML = `
          <td class="py-1.5 px-2 text-kernel-500 font-mono">${e.num}</td>
          <td class="py-1.5 px-2 font-mono text-green-400">${e.F.toFixed(3)}</td>
          <td class="py-1.5 px-2 font-mono text-red-400">${e.IC.toFixed(3)}</td>
          <td class="py-1.5 px-2 font-mono text-amber-400">${e.delta.toFixed(3)}</td>
          <td class="py-1.5 px-2 font-mono text-kernel-400">${e.omega.toFixed(3)}</td>
          <td class="py-1.5 px-2 ${rc} font-bold">${e.regime}</td>
          <td class="py-1.5 px-2 ${sc} font-bold">${e.stance}</td>
          <td class="py-1.5 px-2 text-kernel-500">${e.weakChannel}</td>
        `;
        body.appendChild(tr);
      });

      drawTrajectory();
    }

    function drawTrajectory() {
      const canvas = document.getElementById('trajectory-canvas') as HTMLCanvasElement;
      if (!canvas || sessionHistory.length < 1) return;
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width, hh = canvas.height;
      const pad = { top: 15, right: 20, bottom: 20, left: 40 };
      const pw = w - pad.left - pad.right;
      const ph = hh - pad.top - pad.bottom;

      ctx.clearRect(0, 0, w, hh);

      // Grid
      ctx.strokeStyle = 'rgba(150, 150, 150, 0.1)';
      ctx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = pad.top + (ph * i / 4);
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
      }

      const n = sessionHistory.length;
      const maxN = Math.max(n, 2);

      function plotLine(data: number[], color: string) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        data.forEach((v, i) => {
          const x = pad.left + (i / (maxN - 1)) * pw;
          const y = pad.top + ph * (1 - v);
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();
        // Dots
        data.forEach((v, i) => {
          const x = pad.left + (i / (maxN - 1)) * pw;
          const y = pad.top + ph * (1 - v);
          ctx.beginPath();
          ctx.arc(x, y, 3, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.fill();
        });
      }

      plotLine(sessionHistory.map(e => e.F), '#4ade80');
      plotLine(sessionHistory.map(e => e.IC), '#f87171');

      // Axis labels
      ctx.fillStyle = '#71717a';
      ctx.font = '9px monospace';
      ctx.textAlign = 'right';
      ctx.fillText('1.0', pad.left - 5, pad.top + 4);
      ctx.fillText('0.0', pad.left - 5, pad.top + ph + 4);
      ctx.textAlign = 'center';
      ctx.fillText('evaluation #', pad.left + pw / 2, hh - 2);

      // Legend
      ctx.textAlign = 'left';
      ctx.fillStyle = '#4ade80';
      ctx.fillText('F', w - pad.right - 50, pad.top + 10);
      ctx.fillStyle = '#f87171';
      ctx.fillText('IC', w - pad.right - 30, pad.top + 10);
    }

    document.getElementById('btn-clear-history')?.addEventListener('click', () => {
      sessionHistory.length = 0;
      renderHistory();
    });

    /* ═══════════════════════════════════════════════════════════
       §5  ROSETTA CROSS-DOMAIN LENS
       ═══════════════════════════════════════════════════════════ */
    interface RosettaLens {
      label: string;
      drift: string;
      fidelity: string;
      roughness: string;
      return_: string;
      integrity: string;
    }
    const ROSETTA_LENSES: Record<string, RosettaLens> = {
      epistemology: {
        label: 'Epistemological Reading',
        drift: 'Change in belief, evidence, or warrant',
        fidelity: 'Retained justification, surviving warrant',
        roughness: 'Inference friction, reasoning gaps',
        return_: 'Justified re-entry to the claim',
        integrity: 'Coherence of the epistemic chain',
      },
      ontology: {
        label: 'Ontological Reading',
        drift: 'State transition, departure from being',
        fidelity: 'Conserved properties, what endures',
        roughness: 'Heterogeneity, interface seams',
        return_: 'Restored coherence of structure',
        integrity: 'Unitarity of ontological composition',
      },
      phenomenology: {
        label: 'Phenomenological Reading',
        drift: 'Perceived shift in experience',
        fidelity: 'Stable features of the lifeworld',
        roughness: 'Distress, bias, cognitive effort',
        return_: 'Coping or repair that holds',
        integrity: 'Lived coherence of the experience',
      },
      history: {
        label: 'Historical Reading',
        drift: 'Periodization — what shifted between eras',
        fidelity: 'Continuity — what endures across the longue durée',
        roughness: 'Rupture, confounding factors',
        return_: 'Restitution, reconciliation, reform',
        integrity: 'Historical coherence of the narrative',
      },
      policy: {
        label: 'Policy Reading',
        drift: 'Regime shift, mandate departure',
        fidelity: 'Compliance, mandate persistence',
        roughness: 'Friction, cost, externalities',
        return_: 'Reinstatement, public acceptance',
        integrity: 'Governance coherence of the system',
      },
      semiotics: {
        label: 'Semiotic Reading',
        drift: 'Sign drift — departure from referent',
        fidelity: 'Ground persistence — convention that survived',
        roughness: 'Translation friction — meaning loss across contexts',
        return_: 'Interpretant closure — sign chain returns to grounded meaning',
        integrity: 'Semiotic coherence of the sign system',
      },
    };

    const CE_WORDS = ['Drift', 'Fidelity', 'Roughness', 'Return', 'Integrity'];
    const CE_MEANINGS = [
      'What moved — salient change relative to Contract',
      'What persisted — structure that survived collapse',
      'Where/why it was bumpy — friction, confound, seam',
      'Credible re-entry — how the claim returns to legitimacy',
      'Does it hang together under the Contract? (derived, never asserted)',
    ];

    function renderRosetta(lens: string) {
      const data = ROSETTA_LENSES[lens];
      if (!data) return;
      document.getElementById('lens-header')!.textContent = data.label;

      const body = document.getElementById('rosetta-body')!;
      body.innerHTML = '';
      const lensValues = [data.drift, data.fidelity, data.roughness, data.return_, data.integrity];
      const wordColors = ['text-amber-400', 'text-green-400', 'text-orange-400', 'text-cyan-400', 'text-purple-400'];

      CE_WORDS.forEach((word, i) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-kernel-800/30';
        tr.innerHTML = `
          <td class="py-2 px-3 font-bold ${wordColors[i]} text-sm">${word}</td>
          <td class="py-2 px-3 text-kernel-400">${CE_MEANINGS[i]}</td>
          <td class="py-2 px-3 text-kernel-300">${lensValues[i]}</td>
        `;
        body.appendChild(tr);
      });
    }

    // Lens buttons
    document.querySelectorAll<HTMLButtonElement>('.lens-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.lens-btn').forEach(b => {
          b.classList.remove('bg-amber-500/20', 'text-amber-400', 'border-amber-500/30', 'font-medium');
          b.classList.add('text-kernel-500', 'border-kernel-700/30');
        });
        btn.classList.add('bg-amber-500/20', 'text-amber-400', 'border-amber-500/30', 'font-medium');
        btn.classList.remove('text-kernel-500', 'border-kernel-700/30');
        renderRosetta(btn.dataset.lens!);
      });
    });
    renderRosetta('epistemology');

    /* ── Initial evaluation on page load ──── */
    runEvaluation();
  </script>
</BaseLayout>
