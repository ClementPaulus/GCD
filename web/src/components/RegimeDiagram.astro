---
/**
 * Interactive Regime Phase Diagram
 * Port of: dashboard/pages_core.py render_regime_page()
 *
 * Canvas-based 2D phase diagram showing regime boundaries.
 * Computes kernel across a grid and renders in real-time.
 */
---

<div id="regime-diagram" class="space-y-4">
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
    <h2 class="text-xl font-bold text-kernel-100 mb-2">Regime Phase Diagram</h2>
    <p class="text-kernel-400 text-sm">
      Two-channel phase space showing regime boundaries. Drag the cursor to explore.
      Colors: <span class="text-green-400">Stable (12.5%)</span> ·
      <span class="text-yellow-400">Watch (24.4%)</span> ·
      <span class="text-red-400">Collapse (63.1%)</span>
    </p>
  </div>

  <!-- Controls -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-3">
      <label class="text-xs text-kernel-500">Channels (n)</label>
      <input id="regime-n" type="number" min="2" max="64" value="8"
        class="w-full mt-1 px-2 py-1 bg-kernel-800 border border-kernel-600 rounded text-kernel-200 text-sm" />
    </div>
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-3">
      <label class="text-xs text-kernel-500">Resolution</label>
      <select id="regime-res"
        class="w-full mt-1 px-2 py-1 bg-kernel-800 border border-kernel-600 rounded text-kernel-200 text-sm">
        <option value="50">50×50 (fast)</option>
        <option value="100" selected>100×100</option>
        <option value="200">200×200 (detailed)</option>
      </select>
    </div>
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-3">
      <label class="text-xs text-kernel-500">X-axis</label>
      <select id="regime-x"
        class="w-full mt-1 px-2 py-1 bg-kernel-800 border border-kernel-600 rounded text-kernel-200 text-sm">
        <option value="omega" selected>ω (Drift)</option>
        <option value="F">F (Fidelity)</option>
        <option value="C">C (Curvature)</option>
      </select>
    </div>
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-3">
      <label class="text-xs text-kernel-500">Y-axis</label>
      <select id="regime-y"
        class="w-full mt-1 px-2 py-1 bg-kernel-800 border border-kernel-600 rounded text-kernel-200 text-sm">
        <option value="C" selected>C (Curvature)</option>
        <option value="S">S (Entropy)</option>
        <option value="IC">IC (Integrity)</option>
      </select>
    </div>
  </div>

  <!-- Canvas -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <div class="relative" style="max-width: 560px;">
      <canvas id="phase-canvas"
        class="w-full cursor-crosshair rounded border border-kernel-600"
        style="height: 520px;">
      </canvas>
      <div id="phase-tooltip" class="absolute hidden pointer-events-none text-xs font-mono bg-kernel-900/95 border border-kernel-600 rounded px-2 py-1 text-kernel-200 shadow-lg z-10 whitespace-nowrap"></div>
    </div>
  </div>

  <!-- Hover info -->
  <div id="hover-info" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 text-sm text-kernel-300 hidden">
    <div class="grid grid-cols-3 md:grid-cols-6 gap-2" id="hover-values"></div>
  </div>

  <!-- Regime partition -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Regime Partition (Fisher Space)</h3>
    <div class="flex gap-2 items-center">
      <div class="flex-1">
        <div class="flex h-6 rounded overflow-hidden">
          <div class="bg-green-700" style="width: 12.5%"></div>
          <div class="bg-yellow-700" style="width: 24.4%"></div>
          <div class="bg-red-700" style="width: 63.1%"></div>
        </div>
        <div class="flex justify-between text-xs text-kernel-500 mt-1">
          <span>Stable 12.5%</span>
          <span>Watch 24.4%</span>
          <span>Collapse 63.1%</span>
        </div>
      </div>
    </div>
    <p class="text-xs text-kernel-500 mt-2 italic">
      Stability is rare — 87.5% of the manifold lies outside it.
      Return from collapse to stability is what the axiom measures.
    </p>
  </div>
</div>

<script>
  import { computeKernel, classifyRegime } from '../lib/kernel';
  import type { KernelResult } from '../lib/kernel';

  const canvas = document.getElementById('phase-canvas') as HTMLCanvasElement;
  const hoverInfo = document.getElementById('hover-info')!;
  const hoverValues = document.getElementById('hover-values')!;
  const tooltip = document.getElementById('phase-tooltip')!;

  const COLORS = {
    STABLE: [14, 140, 100],
    WATCH: [180, 120, 30],
    COLLAPSE: [180, 50, 50],
  };
  const CRITICAL_TINT = [120, 50, 180];

  let currentResults: (KernelResult | null)[][] = [];
  let phaseArea: { m: any; plotW: number; plotH: number; cssW: number; cssH: number } | null = null;

  function renderPhaseDiagram() {
    const res = parseInt((document.getElementById('regime-res') as HTMLSelectElement).value);
    const nChannels = parseInt((document.getElementById('regime-n') as HTMLInputElement).value);

    const container = canvas.parentElement!;
    const cssW = Math.min(container.clientWidth, 560);
    const cssH = 520;
    const dpr = window.devicePixelRatio || 1;

    canvas.width = Math.round(cssW * dpr);
    canvas.height = Math.round(cssH * dpr);
    canvas.style.width = cssW + 'px';
    canvas.style.height = cssH + 'px';

    const ctx = canvas.getContext('2d')!;
    ctx.scale(dpr, dpr);

    const m = { top: 20, right: 16, bottom: 48, left: 52 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;
    phaseArea = { m, plotW, plotH, cssW, cssH };

    // Background
    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // Render phase diagram as offscreen then draw smoothly
    const offscreen = new OffscreenCanvas(res, res);
    const octx = offscreen.getContext('2d')!;
    const imageData = octx.createImageData(res, res);
    currentResults = [];

    for (let py = 0; py < res; py++) {
      const row: (KernelResult | null)[] = [];
      const c2 = 1.0 - (py / (res - 1));
      for (let px = 0; px < res; px++) {
        const c1 = px / (res - 1);
        const c = Array(nChannels).fill(0.5);
        c[0] = c1;
        c[1] = c2;

        const result = computeKernel(c);
        const { regime, isCritical } = classifyRegime(result);
        row.push(result);

        const color = COLORS[regime];
        const idx = (py * res + px) * 4;
        if (isCritical) {
          imageData.data[idx] = Math.floor((color[0] * 0.6 + CRITICAL_TINT[0] * 0.4));
          imageData.data[idx + 1] = Math.floor((color[1] * 0.6 + CRITICAL_TINT[1] * 0.4));
          imageData.data[idx + 2] = Math.floor((color[2] * 0.6 + CRITICAL_TINT[2] * 0.4));
        } else {
          imageData.data[idx] = color[0];
          imageData.data[idx + 1] = color[1];
          imageData.data[idx + 2] = color[2];
        }
        imageData.data[idx + 3] = 255;
      }
      currentResults.push(row);
    }
    octx.putImageData(imageData, 0, 0);

    // Draw smooth-scaled into plot area
    ctx.imageSmoothingEnabled = false;
    ctx.drawImage(offscreen, m.left, m.top, plotW, plotH);

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    // Grid + tick labels
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '11px ui-monospace, monospace';
    const ticks = 4;
    ctx.strokeStyle = 'rgba(255,255,255,0.12)';
    ctx.lineWidth = 0.5;

    ctx.textAlign = 'center';
    for (let i = 0; i <= ticks; i++) {
      const val = i / ticks;
      const x = m.left + (i / ticks) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.beginPath(); ctx.moveTo(x, m.top + plotH); ctx.lineTo(x, m.top + plotH + 5); ctx.stroke();
      ctx.strokeStyle = 'rgba(255,255,255,0.12)';
      ctx.fillText(val.toFixed(2), x, m.top + plotH + 18);
    }
    ctx.textAlign = 'right';
    for (let i = 0; i <= ticks; i++) {
      const val = 1 - i / ticks;
      const y = m.top + (i / ticks) * plotH;
      ctx.beginPath(); ctx.moveTo(m.left, y); ctx.lineTo(m.left + plotW, y); ctx.stroke();
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.beginPath(); ctx.moveTo(m.left - 5, y); ctx.lineTo(m.left, y); ctx.stroke();
      ctx.strokeStyle = 'rgba(255,255,255,0.12)';
      ctx.fillText(val.toFixed(2), m.left - 8, y + 4);
    }

    // Axis titles
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '12px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('c₁ (channel 1)', m.left + plotW / 2, cssH - 6);
    ctx.save();
    ctx.translate(14, m.top + plotH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('c₂ (channel 2)', 0, 0);
    ctx.restore();

    // Legend
    const legX = m.left + plotW - 130;
    const legY = m.top + 8;
    ctx.fillStyle = 'rgba(6,6,12,0.85)';
    ctx.fillRect(legX - 4, legY - 2, 134, 72);
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.strokeRect(legX - 4, legY - 2, 134, 72);
    const legend: [string, number[], string][] = [
      ['Stable (12.5%)', COLORS.STABLE, '#34d399'],
      ['Watch (24.4%)', COLORS.WATCH, '#fbbf24'],
      ['Collapse (63.1%)', COLORS.COLLAPSE, '#f87171'],
      ['Critical overlay', CRITICAL_TINT, '#a78bfa'],
    ];
    ctx.font = '10px ui-sans-serif, system-ui, sans-serif';
    legend.forEach(([label, _, textColor], i) => {
      ctx.fillStyle = `rgb(${_[0]},${_[1]},${_[2]})`;
      ctx.fillRect(legX, legY + i * 16, 12, 12);
      ctx.fillStyle = textColor;
      ctx.textAlign = 'left';
      ctx.fillText(label, legX + 16, legY + i * 16 + 10);
    });

    // Info line
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillText(`n=${nChannels} channels · ${res}×${res} grid`, m.left + 4, m.top + 14);
  }

  // Hover handler
  canvas.addEventListener('mousemove', (e) => {
    if (!phaseArea) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const { m, plotW, plotH } = phaseArea;

    if (mx < m.left || mx > m.left + plotW || my < m.top || my > m.top + plotH) {
      hoverInfo.classList.add('hidden');
      tooltip.classList.add('hidden');
      return;
    }

    const res = currentResults.length;
    const px = Math.floor(((mx - m.left) / plotW) * (res - 1));
    const py = Math.floor(((my - m.top) / plotH) * (res - 1));
    if (px < 0 || px >= res || py < 0 || py >= res) return;

    const result = currentResults[py]?.[px];
    if (!result) return;

    const { regime, isCritical } = classifyRegime(result);

    hoverInfo.classList.remove('hidden');
    hoverValues.innerHTML = [
      { label: 'F', value: result.F },
      { label: 'ω', value: result.omega },
      { label: 'S', value: result.S },
      { label: 'C', value: result.C },
      { label: 'κ', value: result.kappa },
      { label: 'IC', value: result.IC },
    ].map(v => `
      <div class="bg-kernel-800 rounded p-1 text-center">
        <div class="text-xs text-kernel-500">${v.label}</div>
        <div class="font-mono text-xs">${v.value.toFixed(4)}</div>
      </div>
    `).join('') + `
      <div class="bg-kernel-800 rounded p-1 text-center col-span-3 md:col-span-6">
        <span class="text-xs ${regime === 'STABLE' ? 'text-green-400' : regime === 'WATCH' ? 'text-yellow-400' : 'text-red-400'}">
          ${regime}${isCritical ? ' + CRITICAL' : ''} · Δ = ${result.delta.toFixed(4)}
        </span>
      </div>
    `;

    const regColor = regime === 'STABLE' ? '#34d399' : regime === 'WATCH' ? '#fbbf24' : '#f87171';
    tooltip.innerHTML = `<span style="color:${regColor}">${regime}</span> F=${result.F.toFixed(3)} ω=${result.omega.toFixed(3)}`;
    tooltip.style.left = (mx + 14) + 'px';
    tooltip.style.top = (my - 10) + 'px';
    tooltip.classList.remove('hidden');
  });

  canvas.addEventListener('mouseleave', () => {
    hoverInfo.classList.add('hidden');
    tooltip.classList.add('hidden');
  });

  ['regime-res', 'regime-n', 'regime-x', 'regime-y'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderPhaseDiagram);
  });

  renderPhaseDiagram();
</script>
