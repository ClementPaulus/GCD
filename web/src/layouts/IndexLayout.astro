---
/**
 * Root index layout — the domain network overview.
 */
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title = 'GCD Kernel', description = '' } = frontmatter || {};
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <div class="text-center mb-16 mt-8">
    <h1 class="text-5xl font-bold tracking-tight mb-4">
      GCD<span class="text-kernel-500">·</span>Kernel
    </h1>
    <p class="text-xl text-kernel-400 mb-2">
      <em>Collapse is generative; only what returns is real.</em>
    </p>
    <p class="text-sm text-kernel-500">
      20 autonomous domain sites · Headless Contract Gateway · UMCP v2.2.5
    </p>

    <!-- Spine visualization -->
    <div class="mt-8 flex items-center justify-center gap-2 text-xs font-mono text-kernel-500">
      <span class="px-2 py-1 bg-kernel-800 rounded">CONTRACT</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">CANON</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">CLOSURES</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">LEDGER</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">STANCE</span>
      <span>→</span>
      <span class="px-2 py-1 bg-blue-900/50 text-blue-400 rounded border border-blue-800">PUBLISH</span>
    </div>
  </div>

  <!-- Content (generated markdown table of domains) -->
  <article class="prose prose-invert prose-sm max-w-none
    prose-table:w-full
    prose-th:text-left prose-th:text-kernel-400 prose-th:font-normal prose-th:border-b prose-th:border-kernel-700 prose-th:py-2
    prose-td:py-2 prose-td:border-b prose-td:border-kernel-800
    prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline">
    <slot />
  </article>
</BaseLayout>
